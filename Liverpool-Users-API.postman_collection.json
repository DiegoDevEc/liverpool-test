          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"paternalLastName\": \"López\",\n  \"email\": \"no-es-un-email\",\n  \"postalCode\": \"ABC\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            },
            "description": "Demuestra validaciones: name vacío, email inválido y postalCode con letras."
          },
          "response": [
            {
              "name": "400 Bad Request — Validación fallida",
              "originalRequest": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {"mode": "raw", "raw": "{\n  \"name\": \"\",\n  \"email\": \"no-es-un-email\",\n  \"postalCode\": \"ABC\"\n}"},
                "url": {"raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"]}
              },
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"timestamp\": \"2026-02-25T10:30:45.123456\",\n  \"status\": 400,\n  \"error\": \"Bad Request\",\n  \"message\": \"name: must not be blank, email: must be a well-formed email address, postalCode: must match \\\"^\\\\d{5}$\\\"\"\n}"
            }
          ]
        },
        {
          "name": "Crear usuario — Error 409 (email duplicado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test('Mensaje de email duplicado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.message).to.include('Email already registered');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ana\",\n  \"paternalLastName\": \"López\",\n  \"maternalLastName\": \"Martínez\",\n  \"email\": \"ana.lopez@example.com\",\n  \"postalCode\": \"06600\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            },
            "description": "Enviar el mismo email que ya fue registrado. Ejecutar después de 'Crear usuario — Exitoso'."
          },
          "response": [
            {
              "name": "409 Conflict — Email duplicado",
              "originalRequest": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {"mode": "raw", "raw": "{\n  \"name\": \"Ana\",\n  \"email\": \"ana.lopez@example.com\",\n  \"postalCode\": \"06600\"\n}"},
                "url": {"raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"]}
              },
              "status": "Conflict",
              "code": 409,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"timestamp\": \"2026-02-25T10:30:45.123456\",\n  \"status\": 409,\n  \"error\": \"Conflict\",\n  \"message\": \"Email already registered\"\n}"
            }
          ]
        }
      ]
    },
